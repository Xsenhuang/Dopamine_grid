<!--pages/index/index.wxml-->
<view class="container">
  <!-- 用户信息栏 -->
  <view class="user-bar">
    <!-- 登录入口已隐藏，后续开放登录时取消注释
    <view class="user-info" bindtap="goToLogin">
      <block wx:if="{{isLoggedIn && userInfo}}">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <text class="user-name">{{userInfo.nickName}}</text>
      </block>
      <block wx:else>
        <view class="user-avatar-default">
          <text class="user-avatar-icon">👤</text>
        </view>
        <text class="user-name">登录</text>
      </block>
    </view>
    -->
    <!-- 体验模式：只显示标题 -->
    <view class="app-title">
      <image class="app-icon" src="/assets/images/avatar.png" mode="aspectFit"></image>
      <text class="app-name">欢迎使用多巴胺打卡</text>
    </view>
    <view class="layout-selector" bindtap="showLayoutDropdown">
      <text class="layout-selector-text">布局 {{gridSize}}×{{gridSize}}</text>
      <text class="layout-selector-arrow">▼</text>
    </view>
  </view>

  <!-- 进度卡片 -->
  <view class="card progress-card">
    <view class="progress-header">
      <view class="progress-text">
        <text class="progress-title">今日完成进度</text>
        <text class="progress-subtitle">{{progressText}}</text>
      </view>
      <view class="progress-circle">
        <view class="circle-bg">
          <text class="percentage">{{completedCount}}/{{totalCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 多巴胺格子 -->
  <view class="card bingo-card">
    <view class="bingo-grid" style="grid-template-columns: repeat({{gridSize}}, 1fr);">
      <!-- 已有任务的格子 -->
      <view
        wx:for="{{tasks}}"
        wx:for-index="index"
        wx:key="id"
        class="bingo-cell {{item.completed ? 'completed' : ''}} {{item.animating ? 'pulse' : ''}} {{item.dragging ? 'dragging' : ''}} {{selectedTaskId === item.id ? 'selected' : ''}} {{item.showConfetti ? 'has-confetti' : ''}}"
        style="background-color: {{item.color}}; display: {{index < gridSize * gridSize ? 'flex' : 'none'}};"
        bindtap="toggleTask"
        data-id="{{item.id}}"
        bindlongpress="startDrag"
        data-index="{{index}}"
        bindtouchmove="onDragMove"
        bindtouchend="onDragEnd"
      >
        <!-- 格子完成时的彩纸效果 -->
        <view wx:if="{{item.showConfetti}}" class="cell-confetti-container">
          <view wx:for="{{item.cellConfetti}}" wx:for-item="confetti" wx:key="id" class="cell-confetti {{confetti.shape}} {{confetti.color}} dir-{{confetti.direction}}" style="{{confetti.direction === 'top' || confetti.direction === 'bottom' ? 'left: ' + confetti.position + '%;' : 'top: ' + confetti.position + '%;'}} animation-delay: {{confetti.delay}}s; animation-duration: {{confetti.duration}}s; transform: rotate({{confetti.rotation}}deg);"></view>
        </view>
        <text class="cell-text" style="color: {{item.completed || selectedTaskId === item.id ? 'white' : (item.textColor || '#666666')}};">{{item.name}}</text>
      </view>
      <!-- 空格子（带加号） -->
      <view
        wx:for="{{emptyCells}}"
        wx:for-index="index"
        wx:key="index"
        class="bingo-cell empty-cell"
        bindtap="showAddTaskModal"
      >
        <text class="empty-cell-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 底部功能按钮 -->
  <view class="bottom-actions">
    <view class="action-btn primary" bindtap="goToTasks">
      <text class="btn-text">任务管理</text>
    </view>
    <view class="action-btn" bindtap="randomizeTasks">
      <text class="btn-text">随机</text>
    </view>
    <view class="action-btn" bindtap="resetAll">
      <text class="btn-text">重置</text>
    </view>
    <view class="action-btn" bindtap="goToStats">
      <text class="btn-text">统计</text>
    </view>
  </view>
</view>

<!-- 布局选择下拉菜单 -->
<view wx:if="{{showLayoutDropdown}}" class="dropdown-overlay" bindtap="hideLayoutDropdown">
  <view class="dropdown-menu" catchtap="preventHide">
    <view 
      wx:for="{{[3, 4, 5, 6]}}" 
      wx:key="*this" 
      class="dropdown-item {{gridSize === item ? 'selected' : ''}}"
      bindtap="selectGridSize"
      data-size="{{item}}"
    >
      <text class="dropdown-item-text">{{item}}×{{item}}</text>
      <text wx:if="{{gridSize === item}}" class="dropdown-check">✓</text>
    </view>
  </view>
</view>

<!-- 完成庆祝弹窗 -->
<view wx:if="{{showCelebration}}" class="celebration-overlay" bindtap="hideCelebration">
  <view class="celebration-content">
    <text class="celebration-emoji">🎉</text>
    <text class="celebration-title">太棒了！</text>
    <text class="celebration-text">你完成了今日所有任务！</text>
  </view>
</view>

<!-- BINGO 连线弹窗 -->
<view wx:if="{{showBingoModal}}" class="bingo-modal-overlay" bindtap="hideBingoModal">
  <!-- 彩纸烟花效果 -->
  <view class="confetti-container">
    <view wx:for="{{confettiPieces}}" wx:key="id" class="confetti {{item.shape}} {{item.color}}" style="left: {{item.left}}%; animation-delay: {{item.delay}}s; animation-duration: {{item.duration}}s; transform: rotate({{item.rotation}}deg);"></view>
  </view>
  <view class="bingo-modal-content" catchtap="preventHide">
    <view class="bingo-modal-icon">👑</view>
    <view class="bingo-modal-title">BINGO! ! !</view>
    <view class="bingo-modal-tag">
      <text class="tag-icon">🎯</text>
      <text class="tag-text">连成 {{bingoLineCount}} 条线!</text>
    </view>
    <view class="bingo-modal-subtitle">多巴胺大爆发! ! 🔥</view>
    <view class="bingo-modal-btn" bindtap="hideBingoModal">
      <text class="btn-text">太棒了，继续!</text>
      <text class="btn-icon">🚀</text>
    </view>
  </view>
</view>

<!-- 日历弹窗 -->
<view wx:if="{{showCalendarModal}}" class="calendar-modal" bindtap="hideCalendar">
  <view class="calendar-content" catchtap="preventHide">
    <!-- 弹窗头部 -->
    <view class="calendar-header">
      <view class="calendar-title">
        <text>日历</text>
      </view>
      <view class="calendar-close" bindtap="hideCalendar">
        <text>✕</text>
      </view>
    </view>
    
    <!-- 年月切换 -->
    <view class="calendar-nav">
      <view class="nav-btn" bindtap="prevMonth">
        <text>‹</text>
      </view>
      <text class="calendar-month">{{calendarYear}}年 {{calendarMonth}}月</text>
      <view class="nav-btn" bindtap="nextMonth">
        <text>›</text>
      </view>
    </view>
    

    
    <!-- 星期标题 -->
    <view class="calendar-weekdays">
      <text wx:for="{{weekdays}}" wx:key="*this" class="weekday">{{item}}</text>
    </view>
    
    <!-- 日期网格 -->
    <view class="calendar-days">
      <view
        wx:for="{{calendarDays}}"
        wx:key="fullDate"
        class="calendar-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        bindtap="selectDate"
        data-date="{{item.date}}"
        data-fulldate="{{item.fullDate}}"
      >
        <text class="day-number">{{item.day}}</text>
        <view wx:if="{{item.hasData}}" class="day-dot"></view>
      </view>
    </view>
    
    <!-- 选中日期详情 -->
    <view class="calendar-detail">
      <view class="detail-header">
        <text class="detail-date">{{selectedDateText}}</text>
        <text wx:if="{{selectedDateIsToday}}" class="detail-today">· 今天</text>
      </view>
      <view class="detail-stats">
        <text class="detail-percent">完成 {{selectedDatePercent}}%</text>
        <text class="detail-count">· 勾选 {{selectedDateCompleted}} 项</text>
      </view>
      
      <!-- 任务列表 -->
      <view class="detail-tasks">
        <text class="detail-tasks-title">完成时间</text>
        <view wx:if="{{selectedDateTasks.length === 0}}" class="detail-empty">
          <text>暂无完成的任务</text>
        </view>
        <view wx:else class="detail-task-list">
          <view wx:for="{{selectedDateTasks}}" wx:key="name" class="detail-task-item">
            <text class="task-time">{{item.time}}</text>
            <text class="task-name">{{item.name}}</text>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 编辑按钮 - 对所有日期都显示 -->
    <view class="calendar-footer">
      <view class="back-today-btn" bindtap="goToEditToday">
        <text>编辑该日期 ✎</text>
      </view>
    </view>
  </view>
</view>

<!-- 新增任务弹窗 -->
<view wx:if="{{showAddTaskModal}}" class="add-task-modal" bindtap="hideAddTaskModal">
  <view class="add-task-content" catchtap="preventHide">
    <view class="add-task-header">
      <text class="add-task-title">新建任务</text>
      <view class="add-task-close" bindtap="hideAddTaskModal">
        <text>✕</text>
      </view>
    </view>
    <view class="add-task-body">
      <input
        class="add-task-input"
        placeholder="请输入任务名称"
        value="{{newTaskName}}"
        bindinput="onNewTaskInput"
        focus="{{showAddTaskModal}}"
      />
    </view>
    <view class="add-task-footer">
      <view class="add-task-btn cancel" bindtap="hideAddTaskModal">
        <text>取消</text>
      </view>
      <view class="add-task-btn confirm" bindtap="confirmAddTask">
        <text>创建</text>
      </view>
    </view>
  </view>
</view>
