/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

/* ========== 顶部导航 ========== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.header-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.header-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.header-btn-icon {
  font-size: 36rpx;
}

/* 进度卡片 */
.progress-card {
  padding: 40rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.progress-text {
  flex: 1;
}

.progress-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.progress-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.progress-circle {
  width: 120rpx;
  height: 120rpx;
  margin-left: 20rpx;
}

.circle-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-color) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.percentage {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.progress-bar-container {
  width: 100%;
}

.progress-bar-bg {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-light) 0%, var(--primary-color) 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* 多巴胺格子 */
.bingo-card {
  padding: 30rpx;
}

.bingo-grid {
  display: grid;
  gap: 12rpx;
}

.bingo-cell {
  aspect-ratio: 1;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.bingo-cell:active {
  transform: scale(0.95);
}

.bingo-cell.completed {
  opacity: 0.7;
}

.cell-text {
  font-size: 22rpx;
  color: var(--text-primary);
  text-align: center;
  padding: 8rpx;
  z-index: 1;
  word-break: break-all;
}

.checkmark {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--success-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: white;
  font-size: 18rpx;
  font-weight: bold;
}

/* 底部功能按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #F5F5F5 0%, #EEEEEE 100%);
  flex: 1;
  min-width: 0;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-color) 100%);
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.action-btn.primary .btn-text {
  color: white;
}

/* 庆祝弹窗 */
.celebration-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.celebration-content {
  background: white;
  border-radius: 32rpx;
  padding: 80rpx 60rpx;
  text-align: center;
  animation: scaleIn 0.3s ease;
}

@keyframes scaleIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.celebration-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.celebration-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.celebration-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ========== 烟花效果样式 ========== */
.fireworks-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.fireworks-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
}

.firework {
  position: absolute;
  width: 4rpx;
  height: 4rpx;
}

.firework-1 {
  top: 20%;
  left: 30%;
  animation: firework-rise 0.5s ease-out forwards;
}

.firework-2 {
  top: 30%;
  left: 60%;
  animation: firework-rise 0.5s ease-out 0.2s forwards;
}

.firework-3 {
  top: 15%;
  left: 45%;
  animation: firework-rise 0.5s ease-out 0.4s forwards;
}

@keyframes firework-rise {
  0% {
    transform: translateY(200rpx) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateY(0) scale(0);
    opacity: 0;
  }
}

.explosion {
  position: absolute;
  width: 100%;
  height: 100%;
  animation: explode 1s ease-out 0.5s forwards;
  opacity: 0;
}

@keyframes explode {
  0% {
    opacity: 1;
    transform: scale(0);
  }
  50% {
    opacity: 1;
    transform: scale(1);
  }
  100% {
    opacity: 0;
    transform: scale(1.5);
  }
}

.spark {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  top: 50%;
  left: 50%;
}

.spark-1 { background: #FF6B6B; transform: rotate(0deg) translateX(60rpx); }
.spark-2 { background: #4ECDC4; transform: rotate(30deg) translateX(60rpx); }
.spark-3 { background: #45B7D1; transform: rotate(60deg) translateX(60rpx); }
.spark-4 { background: #96CEB4; transform: rotate(90deg) translateX(60rpx); }
.spark-5 { background: #FFEAA7; transform: rotate(120deg) translateX(60rpx); }
.spark-6 { background: #DDA0DD; transform: rotate(150deg) translateX(60rpx); }
.spark-7 { background: #98D8C8; transform: rotate(180deg) translateX(60rpx); }
.spark-8 { background: #F7DC6F; transform: rotate(210deg) translateX(60rpx); }
.spark-9 { background: #BB8FCE; transform: rotate(240deg) translateX(60rpx); }
.spark-10 { background: #85C1E2; transform: rotate(270deg) translateX(60rpx); }
.spark-11 { background: #F8B739; transform: rotate(300deg) translateX(60rpx); }
.spark-12 { background: #6C5CE7; transform: rotate(330deg) translateX(60rpx); }

.bingo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFD700;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.8);
  margin-top: 40rpx;
  animation: bingo-pop 0.5s ease-out 0.8s both;
}

@keyframes bingo-pop {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ========== 日历弹窗样式 ========== */
.calendar-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.calendar-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx 30rpx 50rpx;
  max-height: 85vh;
  animation: slideUp 0.3s ease;
  box-sizing: border-box;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 日历头部 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-icon {
  font-size: 40rpx;
}

.calendar-close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 年月导航 */
.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--text-secondary);
  font-weight: 300;
}

.calendar-month {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-tip {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

/* 星期标题 */
.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.weekday {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 15rpx 0;
}

/* 日期网格 */
.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.calendar-day {
  width: 100%;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.2s ease;
}

.calendar-day:active {
  transform: scale(0.95);
}

.calendar-day.other-month {
  opacity: 0.3;
}

.calendar-day.today {
  background: var(--primary-light);
  border: 2rpx solid var(--primary-color);
}

.calendar-day.selected {
  background: var(--primary-color);
}

.calendar-day.selected .day-number {
  color: white;
}

.day-number {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary-color);
  margin-top: 6rpx;
}

.calendar-day.selected .day-dot {
  background: white;
}

/* 日期详情 */
.calendar-detail {
  background: var(--bg-color);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 15rpx;
}

.detail-date {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-today {
  font-size: 26rpx;
  color: var(--primary-color);
}

.detail-stats {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 25rpx;
}

.detail-percent {
  font-size: 28rpx;
  color: var(--primary-color);
  font-weight: 600;
}

.detail-count {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-tasks-title {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 15rpx;
}

.detail-empty {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.detail-task-list {
  display: flex;
  flex-direction: column;
}

.detail-task-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.detail-task-item:last-child {
  border-bottom: none;
}

.task-time {
  font-size: 26rpx;
  color: var(--text-secondary);
  min-width: 120rpx;
  font-weight: 400;
}

.task-name {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  font-weight: 500;
}

/* 返回今天按钮 */
.calendar-footer {
  padding: 0 20rpx;
}

.back-today-btn {
  background: linear-gradient(135deg, #87CEEB 0%, #5DADE2 100%);
  color: white;
  text-align: center;
  padding: 30rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(93, 173, 226, 0.3);
}

.back-today-btn:active {
  transform: scale(0.98);
}
