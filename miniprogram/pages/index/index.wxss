/* pages/index/index.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

/* ========== 顶部导航 ========== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.header-btn {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: var(--card-bg);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.header-btn:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.header-btn-icon {
  font-size: 36rpx;
}

/* 日期选择器样式 */
.header-date-selector {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 20rpx;
  background: var(--card-bg);
  border-radius: 30rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.header-date-selector:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.header-date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.header-date-arrow {
  font-size: 20rpx;
  color: var(--text-secondary);
}

/* 进度卡片 */
.progress-card {
  padding: 40rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.progress-text {
  flex: 1;
}

.progress-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.progress-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.progress-circle {
  width: 120rpx;
  height: 120rpx;
  margin-left: 20rpx;
}

.circle-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-color) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.percentage {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.progress-bar-container {
  width: 100%;
}

.progress-bar-bg {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-light) 0%, var(--primary-color) 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* 多巴胺格子 */
.bingo-card {
  padding: 24rpx;
  min-height: calc(100vw - 60rpx);
  background: #FFFFFF;
  border-radius: 32rpx;
}

.bingo-grid {
  display: grid;
  gap: 16rpx;
  height: 100%;
  align-content: start;
}

.bingo-cell {
  aspect-ratio: 1;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 4rpx solid transparent;
}

.bingo-cell:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.bingo-cell.completed {
  background-color: #FF9800 !important; /* 活力橙色 */
  opacity: 1;
}

.bingo-cell.completed .cell-text {
  color: white !important;
  opacity: 1;
  font-weight: 600;
}

.bingo-cell.selected {
  border: 4rpx solid #FF9800; /* 橙色边框 */
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.3);
}

.bingo-cell.selected .cell-text {
  color: white !important;
  font-weight: 600;
}

.bingo-cell.dragging {
  opacity: 0.5;
  transform: scale(0.95);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.cell-text {
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  padding: 12rpx;
  z-index: 1;
  word-break: break-all;
  line-height: 1.3;
}

.checkmark {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 28rpx;
  height: 28rpx;
  background: var(--success-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: white;
  font-size: 18rpx;
  font-weight: bold;
}

/* 底部功能按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #F5F5F5 0%, #EEEEEE 100%);
  flex: 1;
  min-width: 0;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--primary-light) 0%, var(--primary-color) 100%);
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 28rpx;
}

.btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.action-btn.primary .btn-text {
  color: white;
}

/* 庆祝弹窗 */
.celebration-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.celebration-content {
  background: white;
  border-radius: 32rpx;
  padding: 80rpx 60rpx;
  text-align: center;
  animation: scaleIn 0.3s ease;
}

@keyframes scaleIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.celebration-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.celebration-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.celebration-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ========== BINGO 弹窗样式 ========== */
.bingo-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.bingo-modal-content {
  background: #F8F9FA;
  border-radius: 40rpx;
  padding: 60rpx 50rpx;
  width: 560rpx;
  text-align: center;
  animation: scaleIn 0.3s ease;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.bingo-modal-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: crown-bounce 0.6s ease-out;
}

@keyframes crown-bounce {
  0% {
    transform: scale(0) rotate(-20deg);
    opacity: 0;
  }
  50% {
    transform: scale(1.2) rotate(5deg);
  }
  70% {
    transform: scale(0.95) rotate(-3deg);
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.bingo-modal-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #2C3E50;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
  animation: title-pop 0.4s ease-out 0.1s both;
}

@keyframes title-pop {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.bingo-modal-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FFF8E7;
  border: 2rpx solid #FFE4B5;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 30rpx;
  animation: tag-slide 0.4s ease-out 0.2s both;
}

@keyframes tag-slide {
  0% {
    transform: translateY(-20rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.tag-icon {
  font-size: 28rpx;
}

.tag-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #E8A838;
}

.bingo-modal-subtitle {
  font-size: 32rpx;
  font-weight: 500;
  color: #5D6D7E;
  margin-bottom: 50rpx;
  animation: subtitle-fade 0.4s ease-out 0.3s both;
}

@keyframes subtitle-fade {
  0% {
    opacity: 0;
    transform: translateY(10rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.bingo-modal-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #7DD3C0 0%, #5DB8A8 100%);
  border-radius: 50rpx;
  padding: 28rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(125, 211, 192, 0.4);
  animation: btn-pop 0.4s ease-out 0.4s both;
  transition: all 0.2s ease;
}

.bingo-modal-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(125, 211, 192, 0.3);
}

@keyframes btn-pop {
  0% {
    transform: scale(0.9);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.bingo-modal-btn .btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.bingo-modal-btn .btn-icon {
  font-size: 32rpx;
}

/* ========== 彩纸烟花动效 ========== */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 1;
}

.confetti {
  position: absolute;
  top: -20rpx;
  width: 16rpx;
  height: 16rpx;
  opacity: 0.9;
  animation: confetti-fall linear forwards;
}

/* 圆形彩纸 */
.confetti.circle {
  border-radius: 50%;
}

/* 条形彩纸 */
.confetti.bar {
  width: 8rpx;
  height: 24rpx;
  border-radius: 4rpx;
}

/* 方形彩纸 */
.confetti.square {
  border-radius: 2rpx;
}

/* 颜色定义 - 参考图片中的色调 */
.confetti.gold {
  background: #FFD700;
}

.confetti.yellow {
  background: #FFE135;
}

.confetti.orange {
  background: #FFB347;
}

.confetti.light-gold {
  background: #F4E4BC;
}

.confetti.gray {
  background: #C0C0C0;
}

.confetti.white {
  background: #FFFFFF;
}

.confetti.rose {
  background: #FFB6C1;
}

/* 飘落动画 */
@keyframes confetti-fall {
  0% {
    transform: translateY(0) rotate(0deg) translateX(0);
    opacity: 1;
  }
  25% {
    transform: translateY(25vh) rotate(90deg) translateX(20rpx);
  }
  50% {
    transform: translateY(50vh) rotate(180deg) translateX(-20rpx);
    opacity: 0.9;
  }
  75% {
    transform: translateY(75vh) rotate(270deg) translateX(15rpx);
  }
  100% {
    transform: translateY(110vh) rotate(360deg) translateX(0);
    opacity: 0;
  }
}

/* 左右摇摆的飘落动画变体 */
@keyframes confetti-fall-sway {
  0% {
    transform: translateY(0) rotate(0deg) translateX(0);
    opacity: 1;
  }
  20% {
    transform: translateY(20vh) rotate(72deg) translateX(30rpx);
  }
  40% {
    transform: translateY(40vh) rotate(144deg) translateX(-30rpx);
  }
  60% {
    transform: translateY(60vh) rotate(216deg) translateX(25rpx);
    opacity: 0.8;
  }
  80% {
    transform: translateY(80vh) rotate(288deg) translateX(-20rpx);
  }
  100% {
    transform: translateY(110vh) rotate(360deg) translateX(0);
    opacity: 0;
  }
}

/* ========== 日历弹窗样式 ========== */
.calendar-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 2000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ========== 格子彩纸动效 ========== */
.cell-confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: visible;
  pointer-events: none;
  z-index: 10;
}

.cell-confetti {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  opacity: 0.95;
}

/* 从上方飘落的彩纸 */
.cell-confetti.dir-top {
  top: -10rpx;
  animation: cell-confetti-fall-top linear forwards;
}

/* 从下方飘落的彩纸 */
.cell-confetti.dir-bottom {
  bottom: -10rpx;
  animation: cell-confetti-fall-bottom linear forwards;
}

/* 从左方飘落的彩纸 */
.cell-confetti.dir-left {
  left: -10rpx;
  animation: cell-confetti-fall-left linear forwards;
}

/* 从右方飘落的彩纸 */
.cell-confetti.dir-right {
  right: -10rpx;
  animation: cell-confetti-fall-right linear forwards;
}

/* 圆形彩纸 */
.cell-confetti.circle {
  border-radius: 50%;
}

/* 条形彩纸 */
.cell-confetti.bar {
  width: 5rpx;
  height: 14rpx;
  border-radius: 2rpx;
}

/* 方形彩纸 */
.cell-confetti.square {
  border-radius: 1rpx;
}

/* 格子彩纸颜色 */
.cell-confetti.gold {
  background: #FFD700;
}

.cell-confetti.yellow {
  background: #FFE135;
}

.cell-confetti.orange {
  background: #FFB347;
}

.cell-confetti.light-gold {
  background: #F4E4BC;
}

.cell-confetti.white {
  background: #FFFFFF;
}

/* 从上方飘落动画 */
@keyframes cell-confetti-fall-top {
  0% {
    transform: translateY(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateY(80rpx) rotate(360deg) scale(0.6);
    opacity: 0;
  }
}

/* 从下方飘落动画 */
@keyframes cell-confetti-fall-bottom {
  0% {
    transform: translateY(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateY(-80rpx) rotate(-360deg) scale(0.6);
    opacity: 0;
  }
}

/* 从左方飘落动画 */
@keyframes cell-confetti-fall-left {
  0% {
    transform: translateX(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateX(80rpx) rotate(360deg) scale(0.6);
    opacity: 0;
  }
}

/* 从右方飘落动画 */
@keyframes cell-confetti-fall-right {
  0% {
    transform: translateX(0) rotate(0deg) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateX(-80rpx) rotate(-360deg) scale(0.6);
    opacity: 0;
  }
}

.calendar-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx 30rpx 50rpx;
  max-height: 85vh;
  animation: slideUp 0.3s ease;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 日历头部 */
.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-close {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 年月导航 */
.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--text-secondary);
  font-weight: 300;
}

.calendar-month {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}



/* 星期标题 */
.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.weekday {
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 15rpx 0;
}

/* 日期网格 */
.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.calendar-day {
  width: 100%;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.2s ease;
}

.calendar-day:active {
  transform: scale(0.95);
}

.calendar-day.other-month {
  opacity: 0.3;
}

.calendar-day.today {
  background: var(--primary-light);
  border: 2rpx solid var(--primary-color);
}

.calendar-day.selected {
  background: var(--primary-color);
}

.calendar-day.selected .day-number {
  color: white;
}

.day-number {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary-color);
  margin-top: 6rpx;
}

.calendar-day.selected .day-dot {
  background: white;
}

/* 日期详情 */
.calendar-detail {
  background: #F5F7FA;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.detail-date {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-today {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.detail-stats {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.detail-percent {
  font-size: 28rpx;
  color: #5DADE2;
  font-weight: 500;
}

.detail-count {
  font-size: 26rpx;
  color: #5DADE2;
  font-weight: 500;
}

.detail-tasks-title {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
}

.detail-empty {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.detail-task-list {
  display: flex;
  flex-direction: column;
}

.detail-task-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.detail-task-item:last-child {
  border-bottom: none;
}

.task-time {
  font-size: 26rpx;
  color: #999999;
  min-width: 100rpx;
  font-weight: 400;
}

.task-name {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
  font-weight: 500;
}

/* 返回今天按钮 */
.calendar-footer {
  padding: 0 20rpx;
}

.back-today-btn {
  background: linear-gradient(135deg, #87CEEB 0%, #5DADE2 100%);
  color: white;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(93, 173, 226, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.back-today-btn:active {
  transform: scale(0.98);
}
