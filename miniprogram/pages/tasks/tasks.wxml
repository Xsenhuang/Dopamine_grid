<!--pages/tasks/tasks.wxml-->
<view class="container">
  <!-- 已选数量提示 -->
  <view class="selected-hint">
    <text>已选{{selectedTaskIds.length}}个（格子使用前{{gridSize * gridSize}}个）</text>
  </view>

  <!-- 任务分组列表 -->
  <view class="task-groups">
    <!-- 默认分组 -->
    <view class="task-group">
      <view class="group-header">
        <view class="group-title">
          <text>默认分组</text>
        </view>
        <view class="group-select-all {{defaultGroupAllSelected ? 'selected' : ''}}" catchtap="selectAllInGroup" data-group="default">
          <text>{{defaultGroupAllSelected ? '取消' : '全选'}}</text>
        </view>
      </view>
      <view class="group-tasks">
        <view
          wx:for="{{defaultTasks}}"
          wx:for-index="idx"
          wx:key="id"
          class="task-tag {{item.selected ? 'selected' : ''}}"
          style="--tag-bg-color: {{item.color || '#E8F4FD'}}; --tag-dark-color: {{item.darkColor || '#1976D2'}};"
          bindtap="toggleTaskSelection"
          data-id="{{item.id}}"
        >
          <text class="tag-text">{{item.name}}</text>
          <view class="task-actions">
            <view class="task-action-btn edit" catchtap="editTask" data-task="{{item}}">
              <image class="action-icon" src="/assets/icons/edit.svg" mode="aspectFit"/>
            </view>
            <view class="task-action-btn delete" catchtap="deleteTask" data-task-id="{{item.id}}">
              <image class="action-icon" src="/assets/icons/delete.svg" mode="aspectFit"/>
            </view>
          </view>
        </view>
      </view>
      <!-- 添加任务输入区 -->
      <view class="add-task-section">
        <input
          class="task-input"
          placeholder="输入任务，例如：喝一杯美式"
          value="{{newTaskName}}"
          bindinput="onInputChange"
          maxlength="20"
        />
        <view class="add-btn" bindtap="addTask">
          <text>+</text>
        </view>
      </view>
    </view>

    <!-- 其他分组 -->
    <view wx:for="{{groupedTasks}}" wx:key="groupId" wx:for-item="group" wx:if="{{group.groupId !== 'default'}}" class="task-group">
      <view class="group-header">
        <view class="group-title">
          <text>{{group.groupName}}</text>
        </view>
        <view class="group-actions">
          <view class="group-action-btn edit" catchtap="editGroup" data-group-id="{{group.groupId}}" data-group-name="{{group.groupName}}">
            <text>编辑</text>
          </view>
          <view class="group-action-btn delete" catchtap="deleteGroup" data-group-id="{{group.groupId}}">
            <text>删除</text>
          </view>
          <view class="group-select-all {{groupAllSelected[group.groupId] ? 'selected' : ''}}" catchtap="selectAllInGroup" data-group="{{group.groupId}}">
            <text>{{groupAllSelected[group.groupId] ? '取消' : '全选'}}</text>
          </view>
        </view>
      </view>
      <view class="group-tasks">
        <view
          wx:for="{{group.tasks}}"
          wx:for-item="task"
          wx:for-index="taskIdx"
          wx:key="id"
          class="task-tag {{task.selected ? 'selected' : ''}}"
          style="--tag-bg-color: {{task.color || '#E8F4FD'}}; --tag-dark-color: {{task.darkColor || '#1976D2'}};"
          bindtap="toggleTaskSelection"
          data-id="{{task.id}}"
        >
          <text class="tag-text">{{task.name}}</text>
          <view class="task-actions">
            <view class="task-action-btn edit" catchtap="editTask" data-task="{{task}}">
              <image class="action-icon" src="/assets/icons/edit.svg" mode="aspectFit"/>
            </view>
            <view class="task-action-btn delete" catchtap="deleteTask" data-task-id="{{task.id}}">
              <image class="action-icon" src="/assets/icons/delete.svg" mode="aspectFit"/>
            </view>
          </view>
        </view>
      </view>
      <!-- 添加任务输入区 -->
      <view class="add-task-section">
        <input
          class="task-input"
          placeholder="输入任务，例如：喝一杯美式"
          value="{{newTaskNames[group.groupId] || ''}}"
          bindinput="onGroupInputChange"
          data-group-id="{{group.groupId}}"
          maxlength="20"
        />
        <view class="add-btn" bindtap="addTaskToGroup" data-group-id="{{group.groupId}}" data-group-name="{{group.groupName}}">
          <text>+</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 任务灵感按钮（暂时隐藏） -->
  <!-- <view class="inspiration-btn" bindtap="showInspirationModal">
    <text class="inspiration-icon">💡</text>
    <text class="inspiration-text">任务灵感</text>
  </view> -->

  <!-- 新建分组按钮 -->
  <view class="new-group-btn" bindtap="createNewGroup">
    <text>+ 新建分组</text>
  </view>

  <!-- 底部占位，为底部按钮留出空间 -->
  <view class="bottom-spacer"></view>
</view>

<!-- 底部操作按钮区 -->
<view class="action-bar">
  <view class="action-btn {{selectedTaskIds.length === tasks.length && tasks.length > 0 ? 'active' : ''}}" bindtap="selectAll">
    <text>全选</text>
  </view>
  <view class="action-btn" bindtap="randomSelect">
    <text>随机选择</text>
  </view>
  <view class="action-btn primary" bindtap="applySelection">
    <text>应用</text>
  </view>
</view>


