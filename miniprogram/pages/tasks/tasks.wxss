/* pages/tasks/tasks.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* 添加任务卡片 */
.add-task-card {
  margin-bottom: 30rpx;
}

.input-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-input {
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.task-input::placeholder {
  color: var(--text-hint);
}

.color-picker {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-option {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.color-option.selected {
  border-color: var(--primary-color);
  transform: scale(1.1);
}

.add-btn {
  margin-top: 10rpx;
}

/* 格子布局设置卡片 */
.grid-setting-card {
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.grid-options {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.grid-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.grid-option.selected {
  background: var(--primary-light);
  border-color: var(--primary-color);
}

.grid-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.grid-option.selected .grid-text {
  color: var(--primary-color);
}

.grid-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 任务列表卡片 */
.task-list-card {
  padding: 30rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-count {
  font-size: 24rpx;
  color: var(--text-hint);
  background: #F0F0F0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.task-item.editing {
  background: var(--primary-light);
}

.task-info {
  display: flex;
  align-items: center;
  flex: 1;
  gap: 16rpx;
}

.task-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.task-name {
  font-size: 28rpx;
  color: var(--text-primary);
  flex: 1;
}

.task-name.completed {
  text-decoration: line-through;
  color: var(--text-hint);
}

.status-badge {
  font-size: 20rpx;
  color: var(--success-color);
  background: rgba(76, 175, 80, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.task-actions {
  display: flex;
  gap: 20rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: white;
  font-size: 28rpx;
}

.action-icon:active {
  opacity: 0.7;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* 编辑弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 32rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 30rpx;
  text-align: center;
}

.edit-input {
  height: 88rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.modal-content .color-picker {
  margin-bottom: 30rpx;
  justify-content: center;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-actions .btn {
  flex: 1;
}
