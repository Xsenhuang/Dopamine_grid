/* pages/tasks/tasks.wxss */

.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部标题栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.header-icon {
  font-size: 40rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.header-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.header-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
  display: block;
}

/* 底部占位 */
.bottom-spacer {
  height: 120rpx;
}

/* 操作按钮区 - 固定在底部 */
.action-bar {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0F0F0;
  border-radius: 35rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.action-btn.active {
  background: #E3F2FD;
  color: #1976D2;
}

.action-btn.primary {
  background: #64B5F6;
  color: white;
}

.action-btn.random {
  background: #FFF8E1;
  color: #F9A825;
}

/* 布局分配卡片 */
.layout-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.layout-options {
  display: flex;
  gap: 20rpx;
}

.layout-option {
  flex: 1;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}

.layout-option.selected {
  background: #64B5F6;
  color: white;
}

/* 已选数量提示 */
.selected-hint {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

/* 任务分组 */
.task-groups {
  margin-bottom: 30rpx;
}

.task-group {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.group-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.group-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.2s;
}



.group-select-all {
  padding: 8rpx 20rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 25rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.2s;
}

.group-select-all.selected {
  background: #E3F2FD;
  border-color: #1976D2;
  color: #1976D2;
}

/* 分组操作按钮 */
.group-actions {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.group-action-btn {
  padding: 8rpx 20rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  transition: all 0.2s;
}

.group-action-btn.edit {
  border: 2rpx solid #E0E0E0;
  color: #666;
}

.group-action-btn.edit:active {
  background: #F5F5F5;
}

.group-action-btn.delete {
  border: 2rpx solid #FFCDD2;
  color: #EF5350;
}

.group-action-btn.delete:active {
  background: #FFEBEE;
}

.group-tasks {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  transition: all 0.3s;
}



/* 任务标签 */
.task-tag {
  padding: 15rpx 30rpx;
  border: 2rpx solid transparent;
  border-radius: 35rpx;
  font-size: 26rpx;
  color: #666;
  background: white;
  transition: all 0.2s;
}

.task-tag:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.task-tag {
  transition: all 0.2s;
}

.task-tag.selected {
  color: #333;
  border: 2rpx solid #333;
}

/* 添加任务输入区 */
.add-task-section {
  display: flex;
  gap: 15rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F0F0F0;
}

.task-input {
  flex: 1;
  height: 80rpx;
  background: white;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid #E0E0E0;
}

.add-btn {
  width: 80rpx;
  height: 80rpx;
  background: #FF8A65;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(255, 138, 101, 0.3);
}

/* 新建分组按钮 */
.new-group-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 80rpx;
  background: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
