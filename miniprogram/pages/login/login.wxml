<!--pages/login/login.wxml-->
<view class="container">
  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 登录内容区 -->
  <view class="login-content">
    <!-- 体验模式 - 未登录状态 -->
    <block wx:if="{{!isLoggedIn}}">
      <view class="guest-profile">
        <view class="profile-header">
          <!-- 默认头像 -->
          <view class="default-avatar">
            <text class="avatar-icon">👤</text>
          </view>
          <view class="user-info">
            <text class="user-nickname">欢迎使用多巴胺格子</text>
            <text class="user-status">体验模式</text>
          </view>
        </view>

        <view class="guest-message">
          <text class="message-title">🎉 欢迎体验</text>
          <text class="message-text">当前为体验模式，所有功能均可免费使用</text>
          <text class="message-text">后续将开放登录注册，敬请期待</text>
        </view>

        <!-- 暂不开放登录注册，注释掉登录表单 -->
        <!--
        <view class="login-form">
          ... 登录表单代码 ...
        </view>
        -->

        <view class="guest-actions">
          <button class="back-home-btn" bindtap="goBack">
            <text class="btn-text">开始体验</text>
          </button>
        </view>
      </view>
    </block>

    <!-- 已登录状态（保留原有功能，后续使用） -->
    <block wx:else>
      <view class="user-profile">
        <view class="profile-header">
          <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="user-info">
            <text class="user-nickname">{{userInfo.nickName || userInfo.phoneNumber}}</text>
            <text class="user-status">已登录</text>
          </view>
        </view>

        <view class="profile-info">
          <view class="info-item">
            <text class="info-label">手机号</text>
            <text class="info-value">{{userInfo.phoneNumber}}</text>
          </view>
          <view class="info-item" wx:if="{{userInfo.gender}}">
            <text class="info-label">性别</text>
            <text class="info-value">{{userInfo.gender === 1 ? '男' : userInfo.gender === 2 ? '女' : '未知'}}</text>
          </view>
        </view>

        <view class="logout-section">
          <button class="logout-btn" bindtap="onLogout">
            <text class="btn-text">退出登录</text>
          </button>
        </view>
      </view>
    </block>
  </view>
</view>
