/* pages/stats/stats.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.header {
  margin-bottom: 30rpx;
  padding: 20rpx 10rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 概览卡片 */
.overview-card {
  margin-bottom: 30rpx;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.overview-item {
  text-align: center;
  padding: 20rpx 10rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.overview-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.overview-value.completed {
  color: var(--success-color);
}

.overview-value.pending {
  color: var(--warning-color);
}

.overview-value.percentage {
  color: var(--primary-color);
}

.overview-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 图表卡片 */
.chart-card {
  margin-bottom: 30rpx;
}

.circle-chart {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.circle-bg {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  padding: 20rpx;
  background: #F0F0F0;
}

.circle-progress {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circle-inner {
  width: 200rpx;
  height: 200rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.chart-percentage {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.chart-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* 分布卡片 */
.distribution-card {
  margin-bottom: 30rpx;
}

.color-distribution {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.distribution-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dist-color {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dist-info {
  flex: 1;
}

.dist-name {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.dist-bar-bg {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.dist-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.dist-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 80rpx;
  text-align: right;
}

/* 连续记录卡片 */
.streak-card {
  margin-bottom: 30rpx;
}

.streak-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.streak-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.streak-icon {
  font-size: 32rpx;
}

.streak-count {
  font-size: 28rpx;
  font-weight: 600;
  color: white;
}

.streak-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 名言卡片 */
.quote-card {
  text-align: center;
  padding: 50rpx 40rpx;
}

.quote-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 20rpx;
}

.quote-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.6;
  font-style: italic;
}
