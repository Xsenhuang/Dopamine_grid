/* pages/stats/stats.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 日期选择器 - 参考图片样式 */
.date-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
}

.date-nav {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.date-nav:active {
  opacity: 0.6;
}

.date-nav.disabled {
  opacity: 0.3;
  pointer-events: none;
}

.nav-arrow {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.date-display {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
}

.date-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  letter-spacing: 1rpx;
}

/* 卡片标题 */
.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  margin-top: 10rpx;
}

/* 周热力图 */
.heatmap-card {
  margin-bottom: 30rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.heatmap-container {
  display: flex;
  flex-direction: column;
}

.heatmap-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.heatmap-task-label {
  width: 120rpx;
  flex-shrink: 0;
}

.heatmap-days {
  flex: 1;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.heatmap-day-label {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
}

.heatmap-day-label.today {
  background: rgba(124, 77, 255, 0.1);
}

.day-name {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.day-date {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.heatmap-day-label.today .day-name {
  color: var(--primary-color);
  font-weight: 600;
}

.heatmap-day-label.today .day-date {
  color: var(--primary-color);
}

/* 热力图主体 - 移除滚动，全部显示 */
.heatmap-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.heatmap-row {
  display: flex;
  align-items: center;
}

.heatmap-row .heatmap-task-label {
  width: 120rpx;
  flex-shrink: 0;
  padding-right: 16rpx;
  box-sizing: border-box;
}

.task-name {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.heatmap-cell {
  flex: 1;
  height: 56rpx;
  border-radius: 12rpx;
  background: #F0F0F0;
  transition: all 0.2s ease;
}

.heatmap-cell.completed {
  opacity: 1;
  filter: saturate(1.5) brightness(0.95);
  box-shadow: inset 0 0 0 1rpx rgba(0, 0, 0, 0.05);
}

.heatmap-cell.future {
  background: #F8F8F8;
  opacity: 0.4;
}

/* 习惯榜单 */
.ranking-card {
  margin-bottom: 30rpx;
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.ranking-number {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex-shrink: 0;
  min-width: 40rpx;
}

.ranking-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ranking-stats {
  display: flex;
  gap: 20rpx;
  flex-shrink: 0;
}

.ranking-streak {
  font-size: 24rpx;
  color: #FF6B6B;
}

.ranking-total {
  font-size: 24rpx;
  color: #999;
}

/* 日历弹窗 */
.calendar-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.calendar-modal.show {
  opacity: 1;
  visibility: visible;
}

.calendar-content {
  width: 680rpx;
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  transform: scale(0.9);
  transition: transform 0.3s ease;
}

.calendar-modal.show .calendar-content {
  transform: scale(1);
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.calendar-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
  font-size: 28rpx;
  color: #666;
}

.calendar-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.calendar-nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
  font-size: 32rpx;
  color: #333;
  font-weight: 300;
}

.calendar-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.weekday {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 10rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.2s ease;
}

.calendar-day:active {
  background: #F0F0F0;
}

.calendar-day.other-month {
  opacity: 0.3;
}

.calendar-day.today {
  background: #E3F2FD;
}

.calendar-day.today .day-number {
  color: var(--primary-color);
  font-weight: 600;
}

.calendar-day.selected {
  background: var(--primary-color);
}

.calendar-day.selected .day-number {
  color: white;
  font-weight: 600;
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  margin-top: 6rpx;
}

.calendar-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #F0F0F0;
}

.calendar-legend {
  display: flex;
  gap: 30rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.today-dot {
  background: #E3F2FD;
  border: 2rpx solid var(--primary-color);
}

.calendar-today-btn {
  padding: 16rpx 32rpx;
  background: var(--primary-color);
  color: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}
