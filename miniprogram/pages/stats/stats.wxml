<!--pages/stats/stats.wxml-->
<view class="container">
  <!-- 日期选择器 -->
  <view class="date-selector">
    <view class="date-nav" bindtap="onPrevWeek">
      <text class="nav-arrow">‹</text>
    </view>
    <view class="date-display">
      <text class="date-text">{{weekRangeText}}</text>
    </view>
    <view class="date-nav {{isCurrentWeek ? 'disabled' : ''}}" bindtap="onNextWeek">
      <text class="nav-arrow">›</text>
    </view>
  </view>

  <!-- 周热力图 -->
  <view class="card heatmap-card">
    <text class="card-title">周热力图</text>
    <view class="heatmap-container">
      <!-- 星期表头 -->
      <view class="heatmap-header">
        <view class="heatmap-task-label"></view>
        <view class="heatmap-days">
          <view wx:for="{{weekDays}}" wx:key="index" class="heatmap-day-label {{item.isToday ? 'today' : ''}}">
            <text class="day-name">{{item.name}}</text>
            <text class="day-date">{{item.date}}</text>
          </view>
        </view>
      </view>
      <!-- 任务热力图行 -->
      <view class="heatmap-body">
        <view wx:for="{{heatmapTasks}}" wx:key="id" class="heatmap-row">
          <view class="heatmap-task-label">
            <text class="task-name">{{item.name}}</text>
          </view>
          <view class="heatmap-days">
            <view 
              wx:for="{{item.weekStatus}}" 
              wx:for-item="status" 
              wx:for-index="dayIndex"
              wx:key="dayIndex"
              class="heatmap-cell {{status.completed ? 'completed' : ''}} {{status.isFuture ? 'future' : ''}}"
              style="background-color: {{status.completed ? item.color : ''}}"
            ></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 习惯榜单 -->
  <view class="card ranking-card">
    <text class="card-title">习惯榜单</text>
    <view class="ranking-list">
      <view wx:for="{{taskRankings}}" wx:key="id" class="ranking-item">
        <view class="ranking-number">{{index + 1}}.</view>
        <view class="ranking-name">{{item.name}}</view>
        <view class="ranking-stats">
          <text class="ranking-streak" wx:if="{{item.streak > 0}}">连续 {{item.streak}}</text>
          <text class="ranking-total">总计 {{item.total}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 日历弹窗 -->
  <view class="calendar-modal {{showCalendarModal ? 'show' : ''}}" bindtap="onCloseCalendar">
    <view class="calendar-content" catchtap="onCalendarContentTap">
      <view class="calendar-header">
        <view class="calendar-title">选择日期</view>
        <view class="calendar-close" bindtap="onCloseCalendar">✕</view>
      </view>
      
      <view class="calendar-nav">
        <view class="calendar-nav-btn" bindtap="onPrevMonth">‹</view>
        <view class="calendar-month">{{calendarYear}}年{{calendarMonth}}月</view>
        <view class="calendar-nav-btn" bindtap="onNextMonth">›</view>
      </view>
      
      <view class="calendar-weekdays">
        <view wx:for="{{weekdays}}" wx:key="*this" class="weekday">{{item}}</view>
      </view>
      
      <view class="calendar-days">
        <view 
          wx:for="{{calendarDays}}" 
          wx:key="fullDate"
          class="calendar-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
          bindtap="onDaySelect"
          data-date="{{item.fullDate}}"
          data-istoday="{{item.isToday}}"
        >
          <text class="day-number">{{item.day}}</text>
          <view wx:if="{{item.hasData}}" class="day-dot" style="background: {{item.dotColor}}"></view>
        </view>
      </view>
      
      <view class="calendar-footer">
        <view class="calendar-legend">
          <view class="legend-item">
            <view class="legend-dot" style="background: #4CAF50"></view>
            <text>有记录</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot today-dot"></view>
            <text>今天</text>
          </view>
        </view>
        <view class="calendar-today-btn" bindtap="onSelectToday">回到今天</view>
      </view>
    </view>
  </view>
</view>
