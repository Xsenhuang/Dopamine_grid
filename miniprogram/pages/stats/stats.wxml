<!--pages/stats/stats.wxml-->
<view class="container">
  <!-- 日期选择器 -->
  <view class="date-selector">
    <view class="date-nav" bindtap="onPrevDate">
      <text class="nav-arrow">‹</text>
    </view>
    <view class="date-display" bindtap="onSelectDate">
      <text class="date-text">{{currentDateText}}</text>
      <text class="date-icon">📅</text>
    </view>
    <view class="date-nav {{isToday ? 'disabled' : ''}}" bindtap="onNextDate">
      <text class="nav-arrow">›</text>
    </view>
  </view>

  <!-- 今日概览 -->
  <view class="card overview-card">
    <text class="card-title">{{isToday ? '今日概览' : '当日概览'}}</text>
    <view class="overview-grid">
      <view class="overview-item">
        <text class="overview-value">{{todayStats.total}}</text>
        <text class="overview-label">总任务</text>
      </view>
      <view class="overview-item">
        <text class="overview-value completed">{{todayStats.completed}}</text>
        <text class="overview-label">已完成</text>
      </view>
      <view class="overview-item">
        <text class="overview-value pending">{{todayStats.pending}}</text>
        <text class="overview-label">待完成</text>
      </view>
      <view class="overview-item">
        <text class="overview-value percentage">{{todayStats.percentage}}%</text>
        <text class="overview-label">完成率</text>
      </view>
    </view>
  </view>

  <!-- 完成度环形图 -->
  <view class="card chart-card">
    <text class="card-title">完成进度</text>
    <view class="circle-chart">
      <view class="circle-bg">
        <view class="circle-progress" style="background: conic-gradient(var(--primary-color) {{todayStats.percentage * 3.6}}deg, #F0F0F0 0deg);">
          <view class="circle-inner">
            <text class="chart-percentage">{{todayStats.percentage}}%</text>
            <text class="chart-label">已完成</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 颜色分布 -->
  <view class="card distribution-card">
    <text class="card-title">任务分类</text>
    <view class="color-distribution">
      <view 
        wx:for="{{colorStats}}" 
        wx:key="color"
        class="distribution-item"
      >
        <view class="dist-color" style="background-color: {{item.color}}"></view>
        <view class="dist-info">
          <text class="dist-name">{{item.name}}</text>
          <view class="dist-bar-bg">
            <view class="dist-bar-fill" style="width: {{item.percentage}}%; background-color: {{item.color}}"></view>
          </view>
          <text class="dist-tasks" wx:if="{{item.taskNamesText}}">{{item.taskNamesText}}</text>
        </view>
        <text class="dist-count">{{item.count}}个</text>
      </view>
    </view>
  </view>

  <!-- 连续完成天数 -->
  <view class="card streak-card">
    <view class="streak-header">
      <text class="card-title">连续记录</text>
      <view class="streak-badge">
        <text class="streak-icon">🔥</text>
        <text class="streak-count">{{streakDays}} 天</text>
      </view>
    </view>
    <text class="streak-desc">保持连续完成任务的习惯！</text>
  </view>

  <!-- 鼓励语 -->
  <view class="card quote-card">
    <text class="quote-icon">💬</text>
    <text class="quote-text">{{dailyQuote}}</text>
  </view>

  <!-- 日历弹窗 -->
  <view class="calendar-modal {{showCalendarModal ? 'show' : ''}}" bindtap="onCloseCalendar">
    <view class="calendar-content" catchtap="onCalendarContentTap">
      <view class="calendar-header">
        <view class="calendar-title">选择日期</view>
        <view class="calendar-close" bindtap="onCloseCalendar">✕</view>
      </view>
      
      <view class="calendar-nav">
        <view class="calendar-nav-btn" bindtap="onPrevMonth">‹</view>
        <view class="calendar-month">{{calendarYear}}年{{calendarMonth}}月</view>
        <view class="calendar-nav-btn" bindtap="onNextMonth">›</view>
      </view>
      
      <view class="calendar-weekdays">
        <view wx:for="{{weekdays}}" wx:key="*this" class="weekday">{{item}}</view>
      </view>
      
      <view class="calendar-days">
        <view 
          wx:for="{{calendarDays}}" 
          wx:key="fullDate"
          class="calendar-day {{item.isCurrentMonth ? '' : 'other-month'}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
          bindtap="onDaySelect"
          data-date="{{item.fullDate}}"
          data-istoday="{{item.isToday}}"
        >
          <text class="day-number">{{item.day}}</text>
          <view wx:if="{{item.hasData}}" class="day-dot" style="background: {{item.dotColor}}"></view>
        </view>
      </view>
      
      <view class="calendar-footer">
        <view class="calendar-legend">
          <view class="legend-item">
            <view class="legend-dot" style="background: #4CAF50"></view>
            <text>有记录</text>
          </view>
          <view class="legend-item">
            <view class="legend-dot today-dot"></view>
            <text>今天</text>
          </view>
        </view>
        <view class="calendar-today-btn" bindtap="onSelectToday">回到今天</view>
      </view>
    </view>
  </view>
</view>
